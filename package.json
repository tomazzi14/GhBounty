{
  "name": "ghbounty",
  "version": "0.0.0",
  "private": true,
  "description": "Automated GitHub bounty marketplace with AI-verified PRs.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:push": "pnpm --filter @ghbounty/db db:push",
    "db:generate": "pnpm --filter @ghbounty/db db:generate"
  }
}
