# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — NEVER commit secrets.

# --- Supabase ---
# Project URL (e.g. https://kzltawaqgiwoyxxcdofm.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Anon / publishable key (safe to expose in browser, respects RLS).
# Find it in: Supabase Dashboard > Project Settings > API > anon / public
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Toggle real Supabase queries (1) vs in-memory mocks (0).
# Note: even with =0, the middleware/proxy still instantiates the client,
# so the URL + key above are required regardless.
NEXT_PUBLIC_USE_SUPABASE=0

# --- Privy (wallet auth, GHB-75 + GHB-165) ---
# Privy app ID. Public — safe to expose in the browser bundle.
# Find it in: Privy Dashboard > Apps > <your app> > App ID
NEXT_PUBLIC_PRIVY_APP_ID=

# Toggle Privy as the auth provider (takes precedence over Supabase email/pass).
# When =1, the browser uses the /api/auth/privy-bridge route to exchange the
# Privy JWT for a Supabase-compatible HS256 token (signed below). RLS policies
# match `auth.jwt() ->> 'sub'` against `profiles.user_id` (the Privy DID).
NEXT_PUBLIC_USE_PRIVY=0

# --- Supabase JWT secret (GHB-165, server-only!) ---
# Used by /api/auth/privy-bridge to mint HS256 JWTs that Supabase trusts.
# Find it in: Supabase Dashboard > Project Settings > API > JWT Settings
#                                > "JWT Secret" (NOT the publishable key).
# NEVER prefix this with NEXT_PUBLIC_ — leaking it lets anyone forge tokens
# for any user and bypass RLS entirely. Keep it server-side only.
SUPABASE_JWT_SECRET=

# --- Auth bypass (dev only) ---
# Inject a fake user so /app/* renders without going through real auth.
# Useful for testing the data layer in isolation. NEVER enable in prod.
# To switch role: localStorage.setItem("bypassRole", "dev"); reload.
NEXT_PUBLIC_AUTH_BYPASS=0
